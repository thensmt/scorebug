{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "database.rules.json",
      "database.rules.json.local",
      "firebase.json.local",
      "storage.rules",
      ".firebaserc",
      ".env",
      "**/.*",
      "**/node_modules/**",
      "functions/**",
      "scripts/**",
      "gemini-review-package/**",
      "nsmt-scorebug/**",
      "nsmt-wiki/**",
      "**/*.md",
      "**/*.log",
      "**/*-backup*",
      "**/*_backup*",
      "**/*.bak",
      "**/*.py",
      "**/*.csv",
      "**/*.pdf",
      "**/CURRENT_GOLDEN_*",
      "**/ORIGINAL_V2_*",
      "**/live_editing_server*",
      "**/scoreboard_server*",
      "**/websocket-server*",
      "**/nsmt_*",
      "**/nsmt-producer*",
      "**/stats_v3*",
      "**/stats_control*",
      "**/ticker2*",
      "**/ws-client*",
      "uploads/**",
      "**/NSMT_Scorebug_*"
    ],
    "rewrites": [
      {
        "source": "/o/**",
        "destination": "/yolo-overlay.html"
      },
      {
        "source": "/c/**",
        "destination": "/yolo-control.html"
      },
      {
        "source": "/s/**",
        "destination": "/yolo-stats.html"
      }
    ],
    "headers": [
      {
        "source": "**",
        "headers": [
          {
            "key": "Content-Security-Policy",
            "value": "default-src 'none'; script-src 'self' 'unsafe-inline' https://www.gstatic.com https://apis.google.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src https://fonts.gstatic.com; img-src 'self' data: blob: https://*.firebasestorage.app https://firebasestorage.googleapis.com https://storage.googleapis.com; connect-src https://*.firebaseio.com wss://*.firebaseio.com https://*.googleapis.com https://identitytoolkit.googleapis.com https://us-central1-sincere-nirvana-436014-v9.cloudfunctions.net; frame-src 'none'; object-src 'none'; base-uri 'none'; form-action 'self';"
          }
        ]
      },
      {
        "source": "/yolo-overlay.html",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-cache, no-store, must-revalidate"
          }
        ]
      },
      {
        "source": "/yolo-control.html",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-cache, no-store, must-revalidate"
          }
        ]
      },
      {
        "source": "/yolo-stats.html",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-cache, no-store, must-revalidate"
          }
        ]
      }
    ]
  },
  "database": {
    "rules": "database.rules.json"
  },
  "storage": {
    "rules": "storage.rules"
  },
  "functions": {
    "source": "functions",
    "runtime": "nodejs20"
  }
}
