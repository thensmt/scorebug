{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "database.rules.json",
      "database.rules.json.local",
      "firebase.json.local",
      "storage.rules",
      ".firebaserc",
      "**/.*",
      "**/node_modules/**",
      "functions/**",
      "gemini-review-package/**",
      "nsmt-scorebug/**",
      "nsmt-wiki/**",
      "**/*.md",
      "**/*.log"
    ],
    "rewrites": [
      {
        "source": "/o/{eventId}",
        "destination": "/yolo-overlay.html"
      },
      {
        "source": "/c/{eventId}",
        "destination": "/yolo-control.html"
      }
    ],
    "headers": [
      {
        "source": "/yolo-overlay.html",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-cache, no-store, must-revalidate"
          }
        ]
      },
      {
        "source": "/yolo-control.html",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-cache, no-store, must-revalidate"
          }
        ]
      }
    ]
  },
  "database": {
    "rules": "database.rules.json"
  },
  "storage": {
    "rules": "storage.rules"
  },
  "functions": {
    "source": "functions",
    "runtime": "nodejs20"
  }
}
