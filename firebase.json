{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "database.rules.json",
      "database.rules.json.local",
      "firebase.json.local",
      "storage.rules",
      ".firebaserc",
      ".env",
      "**/.*",
      "**/node_modules/**",
      "functions/**",
      "scripts/**",
      "gemini-review-package/**",
      "nsmt-scorebug/**",
      "nsmt-wiki/**",
      "**/*.md",
      "**/*.log",
      "**/*-backup*",
      "**/*_backup*",
      "**/*.bak",
      "**/*.py",
      "**/*.csv",
      "**/*.pdf",
      "**/CURRENT_GOLDEN_*",
      "**/ORIGINAL_V2_*",
      "**/live_editing_server*",
      "**/scoreboard_server*",
      "**/websocket-server*",
      "**/nsmt_*",
      "**/nsmt-producer*",
      "**/stats_v3*",
      "**/stats_control*",
      "**/ticker2*",
      "**/ws-client*",
      "uploads/**",
      "**/NSMT_Scorebug_*"
    ],
    "rewrites": [
      {
        "source": "/o/{eventId}",
        "destination": "/yolo-overlay.html"
      },
      {
        "source": "/c/{eventId}",
        "destination": "/yolo-control.html"
      }
    ],
    "headers": [
      {
        "source": "/yolo-overlay.html",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-cache, no-store, must-revalidate"
          }
        ]
      },
      {
        "source": "/yolo-control.html",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-cache, no-store, must-revalidate"
          }
        ]
      }
    ]
  },
  "database": {
    "rules": "database.rules.json"
  },
  "storage": {
    "rules": "storage.rules"
  },
  "functions": {
    "source": "functions",
    "runtime": "nodejs20"
  }
}
